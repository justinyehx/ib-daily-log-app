# Pooled connection for app/runtime queries
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@[YOUR-POOLER-HOST]:6543/postgres?pgbouncer=true&sslmode=require"

# Direct connection for Prisma migrations
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?sslmode=require"

NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[YOUR-ANON-KEY]"
SUPABASE_SERVICE_ROLE_KEY="[YOUR-SERVICE-ROLE-KEY]"
APP_STORE_DEFAULT="curve"

# BridalLive appointments integration
BRIDALLIVE_BASE_URL="https://api.bridallive.com/bl-server/api"
BRIDALLIVE_RETAILER_ID="[YOUR-BRIDALLIVE-RETAILER-ID]"
BRIDALLIVE_API_KEY="[YOUR-BRIDALLIVE-API-KEY]"

# Optional per-store overrides, if each location uses its own BridalLive account.
# Example:
# BRIDALLIVE_STORE_CONFIG='{"galleria":{"retailerId":"abc","apiKey":"123"},"atlanta":{"retailerId":"def","apiKey":"456"}}'
BRIDALLIVE_STORE_CONFIG=""

CRON_SECRET="[GENERATE-A-RANDOM-SECRET]"
