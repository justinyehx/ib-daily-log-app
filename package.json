{
  "name": "impression-bridal-daily-log",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:turbo": "node scripts/dev.mjs --turbo",
    "preview": "npm run build && npm run start",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "node prisma/seed.mjs",
    "prisma:import:metadata": "node prisma/import-store-metadata.mjs",
    "prisma:import:appointments": "node prisma/import-appointments.mjs",
    "prisma:import:curve": "node prisma/import-appointments.mjs --store=curve",
    "prisma:import:galleria": "node prisma/import-appointments.mjs --store=galleria",
    "prisma:import:atlanta": "node prisma/import-appointments.mjs --store=atlanta",
    "prisma:import:san-antonio": "node prisma/import-appointments.mjs --store=san-antonio"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "@supabase/supabase-js": "^2.49.4",
    "dotenv": "^16.6.1",
    "next": "^15.2.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.24",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.3",
    "prisma": "^6.6.0",
    "typescript": "^5.8.2"
  }
}
